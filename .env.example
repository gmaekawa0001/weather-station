# Supabase — em https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Chave service role (apenas servidor, rota /api/sync) — NÃO exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Opcional: canal ThingSpeak (padrão 3147539)
THINGSPEAK_CHANNEL_ID=3147539
